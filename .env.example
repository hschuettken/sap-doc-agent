# Spec2Sphere — Environment Configuration
# Copy to .env and fill in values before starting the service.
# All vars with defaults are optional. All others are required.

# === Database ===
DATABASE_URL=postgresql+psycopg://sapdoc:sapdoc@postgres:5432/sapdoc

# === Queue + Cache ===
REDIS_URL=redis://redis:6379/0

# === Multi-Tenant ===
MULTI_TENANT=true             # true | false (single-tenant)

# === Modules (comma-separated, overrides config.yaml) ===
# ENABLED_MODULES=core,migration_accelerator,dsp_factory,sac_factory,governance,artifact_lab,multi_tenant

# === LLM — choose ONE provider ===
LLM_PROVIDER=router           # azure | openai | anthropic | vllm | ollama | gemini | router | none

# Azure OpenAI (recommended for enterprise)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-7

# Google Gemini (via OpenAI-compatible endpoint)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-google-ai-studio-key
# GEMINI_MODEL=gemini-2.5-flash

# vLLM (on-prem GPU)
# LLM_PROVIDER=vllm
# VLLM_BASE_URL=http://vllm.internal:8000
# VLLM_MODEL=Qwen2.5-Coder-32B-Instruct
# VLLM_API_KEY=  # optional

# Ollama (on-prem, CPU/small GPU)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:32b

# Homelab LLM Router (dev/demo only)
# LLM_PROVIDER=router
# LLM_ROUTER_URL=http://llm-router:8070
# LLM_ROUTER_API_KEY=your-key

# === LLM Limits (optional) ===
# LLM_TOKEN_BUDGET_PER_HOUR=100000
# LLM_MAX_CONCURRENT=4
# LLM_CHUNK_SIZE_TOKENS=8000

# === Doc Platform — choose ONE ===
# DOC_BACKEND=bookstack
# BOOKSTACK_URL=http://bookstack:80
# BOOKSTACK_TOKEN=your-token

# === SAP System ===
DSP_CLIENT_ID=your-client-id
DSP_CLIENT_SECRET=your-secret
DSP_TOKEN_URL=https://your-tenant.authentication.eu10.hana.ondemand.com/oauth/token

# === Web / Auth ===
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
UI_PASSWORD_HASH=$2b$12$...   # bcrypt hash — generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"

# === Secrets Backend (default: env) ===
# SECRETS_BACKEND=env        # env | vault | azure-kv | aws-sm | envctl

# === Observability (optional) ===
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# LOG_FORMAT=json            # json (default) | text

# === Upload Limits ===
# UPLOAD_MAX_MB=50

# === Scan Rate Limiting ===
# SAP_RATE_LIMIT_RPS=10

# === Worker Concurrency ===
# WORKER_CONCURRENCY_SCAN=4
# WORKER_CONCURRENCY_LLM=2
# WORKER_CONCURRENCY_CHROME=1

# === dsp-ai (AI enhancements — Session A) ===
LLM_ENDPOINT=http://llm-router:8070/v1
LLM_API_KEY=
NEO4J_PASSWORD=change-me
NEO4J_URL=bolt://neo4j:7687
SEARXNG_ENABLED=true
SEARXNG_SECRET=change-me
SEARXNG_URL=http://searxng:8080/search
WIDGET_ALLOWED_ORIGINS=
STUDIO_AUTHOR_EMAILS=
BATCH_CRON=0 6 * * 1-5
BRAIN_FEEDER_CRON=0 */4 * * *
DSPAI_URL=http://dsp-ai:8000
# DSP_DATABASE_URL — optional direct-DB DSN for DspFetcher (defaults to DATABASE_URL)
# DSP_DATABASE_URL=
