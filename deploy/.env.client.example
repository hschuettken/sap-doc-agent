# Required settings for client deployment
# Copy to .env in same directory as docker-compose.client.yml

# PostgreSQL
POSTGRES_DB=sapdoc
POSTGRES_USER=sapdoc
POSTGRES_PASSWORD=change-me-in-production

DATABASE_URL=postgresql+psycopg://sapdoc:change-me-in-production@postgres:5432/sapdoc

# Redis
REDIS_URL=redis://redis:6379/0

# LLM Provider
LLM_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Auth
SECRET_KEY=change-me-use-openssl-rand-hex-32
UI_PASSWORD_HASH=$2b$12$change-me

# SAP
DSP_CLIENT_ID=
DSP_CLIENT_SECRET=
DSP_TOKEN_URL=
